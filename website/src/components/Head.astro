---
import { OgImage } from 'astro-opengraph-image/components';

import instrumentSans400 from '@fontsource/instrument-sans/files/instrument-sans-latin-400-normal.woff2?url';
import instrumentSans500 from '@fontsource/instrument-sans/files/instrument-sans-latin-500-normal.woff2?url';
import instrumentSans600 from '@fontsource/instrument-sans/files/instrument-sans-latin-600-normal.woff2?url';
import instrumentSans700 from '@fontsource/instrument-sans/files/instrument-sans-latin-700-normal.woff2?url';
import ibmPlexMono400 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';
import ibmPlexMono500 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-500-normal.woff2?url';
import ibmPlexMono700 from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-700-normal.woff2?url';

const dotSvg = `data:image/svg+xml,${encodeURIComponent(`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"><circle cx="12" cy="12" r="1" fill="rgba(124,172,248,0.2)"/></svg>`)}`;

const { head, title, description } = Astro.locals.starlightRoute.entry
	? {
			head: Astro.locals.starlightRoute.head,
			title: Astro.locals.starlightRoute.entry.data.title,
		description: ((d) => d.length > 120 ? d.slice(0, 120) + '...' : d)(Astro.locals.starlightRoute.entry.data.description || ''),
	}
	: { head: Astro.locals.starlightRoute.head, title: 'Parseff', description: '' };

const preloadFonts = [
	instrumentSans400,
	instrumentSans500,
	instrumentSans600,
	instrumentSans700,
	ibmPlexMono400,
	ibmPlexMono500,
	ibmPlexMono700,
];

const fontFaces = [
	{ family: 'Instrument Sans', weight: 400, url: instrumentSans400 },
	{ family: 'Instrument Sans', weight: 500, url: instrumentSans500 },
	{ family: 'Instrument Sans', weight: 600, url: instrumentSans600 },
	{ family: 'Instrument Sans', weight: 700, url: instrumentSans700 },
	{ family: 'IBM Plex Mono', weight: 400, url: ibmPlexMono400 },
	{ family: 'IBM Plex Mono', weight: 500, url: ibmPlexMono500 },
	{ family: 'IBM Plex Mono', weight: 700, url: ibmPlexMono700 },
];

const fontFaceCss = fontFaces
	.map(
		(f) => `@font-face {
  font-family: '${f.family}';
  font-style: normal;
  font-display: swap;
  font-weight: ${f.weight};
  src: url('${f.url}') format('woff2');
  unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0300-0301,U+0304,U+0306-0307,U+030A,U+030C,U+0312,U+0327-0328,U+0338,U+0394,U+03A9,U+03B1-03B4,U+03B6,U+03BC,U+03C0,U+03C3,U+2013-2014,U+2018-201A,U+201C-201E,U+2020-2022,U+2026,U+2030,U+2039-203A,U+2044,U+2074,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
}`,
	)
	.join('\n');
---

<OgImage>
	<div style="display: flex; position: relative; width: 100%; height: 100%;">
		<div style={`display: flex; position: absolute; top: 12px; left: 12px; bottom: 12px; right: 12px; background-image: url('${dotSvg}'); background-size: 12px 12px; background-repeat: repeat;`}></div>
		<div style="display: flex; flex-direction: column; justify-content: space-between; width: 100%; height: 100%; padding: 30px; font-family: 'Instrument Sans', sans-serif; gap: 0px; position: relative;">
			<div style="display: flex; flex-direction: row; justify-content: space-between; align-items: center; width: 100%; gap: 12px;">
				<span style="font-size: 20px; font-weight: 700; color: #7CACF8; line-height: 1;">Parseff</span>
				<span style="font-size: 12px; color: #455E86; line-height: 1; border: 1px solid #455E86; padding: 4px 5px; border-radius: 8px; background-color: #101014">documentation</span>
			</div>
			<div style="display: flex; flex-direction: column; justify-content: flex-end; width: 100%; height: 100%; font-family: 'Instrument Sans', sans-serif; padding-bottom: 20px;">
				<span style="font-size: 18px; font-weight: 700; color: #ffffff; line-height: 1;">{title}</span>
				{description && (
					<span style="font-size: 14px; font-weight: 400; color: #b4b4be; line-height: 1.5; margin-top: 12px;">{description}</span>
				)}
			</div>
		</div>
	</div>
	<style is:inline>
		* { margin: 0; padding: 0; }
	</style>
</OgImage>
{preloadFonts.map((href) => (
	<link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
))}
<style is:inline set:html={fontFaceCss} />
{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
